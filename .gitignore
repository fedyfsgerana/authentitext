# ===========================
dist/
build/
frontend/dist/

# ===========================
# Logs
# ===========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===========================
# Cache
# ===========================
.cache/
.vite/
frontend/.vite/
