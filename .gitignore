@"
# ===========================
# Dependencies
# ===========================
node_modules/
frontend/node_modules/

# ===========================
# Environment Variables
# ===========================
.env
.env.local
.env.development
.env.production
.env.test
frontend/.env
frontend/.env.local
*.env

# ===========================
